{
  "mcpServers": {
    "github-wide": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_example_token"
      }
    },
    "local-shell": {
      "command": "node",
      "args": ["./server.js", "--shell", "--write-files"]
    }
  }
}
